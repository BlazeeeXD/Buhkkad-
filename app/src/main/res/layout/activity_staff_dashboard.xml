<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#E9E0D2">


  <androidx.constraintlayout.widget.ConstraintLayout

    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#E9E0D2"> <View
    android:id="@+id/header_bg"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:background="#FFFBF7"
    app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="Staff Dashboard"
        android:textColor="#333333"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manage Cafe Operations"
        android:textColor="#666666"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@id/tv_title"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <ImageView
          android:layout_width="28dp"
          android:layout_height="28dp"
          android:layout_marginEnd="24dp"
          android:src="@drawable/ic_logout"
          app:layout_constraintBottom_toBottomOf="@id/tv_title"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toTopOf="@id/tv_title"
          app:layout_constraintHorizontal_bias="1.0" app:tint="#666666" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/stats_flow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:constraint_referenced_ids="card_orders,card_pending,card_preparing,card_completed"
        app:flow_horizontalGap="12dp"
        app:flow_maxElementsWrap="2"
        app:flow_verticalGap="12dp"
        app:flow_wrapMode="aligned"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bg" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_orders"
        android:layout_width="0dp"
        android:layout_height="140dp"
        app:cardBackgroundColor="#F4EFE9"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        tools:ignore="MissingConstraints">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="14dp">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_circle"
                android:padding="10dp"
                android:src="@drawable/ic_orders" />
            <TextView
                android:id="@+id/order_count_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="2"
                android:textColor="#000000"
                android:textSize="32sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orders Today"
                android:textColor="#333333" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_pending"
        android:layout_width="0dp"
        android:layout_height="140dp"
        app:cardBackgroundColor="#F4EFE9"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        tools:ignore="MissingConstraints">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="14dp">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_circle"
                android:backgroundTint="#D2A273"
                android:padding="10dp"
                android:src="@drawable/ic_pending" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0"
                android:textColor="#000000"
                android:textSize="32sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textColor="#333333" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_preparing"
        android:layout_width="0dp"
        android:layout_height="140dp"
        app:cardBackgroundColor="#F4EFE9"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        tools:ignore="MissingConstraints">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="14dp">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_circle"
                android:backgroundTint="#D2A273"
                android:padding="10dp"
                android:src="@drawable/ic_pending" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="0"
                android:textColor="#000000"
                android:textSize="32sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preparing"
                android:textColor="#333333" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_completed"
        android:layout_width="0dp"
        android:layout_height="140dp"
        app:cardBackgroundColor="#F4EFE9"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        tools:ignore="MissingConstraints">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="14dp">
            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_circle"
                android:backgroundTint="#8BA888"
                android:padding="10dp"
                android:src="@drawable/ic_completed" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="2"
                android:textColor="#000000"
                android:textSize="32sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completed"
                android:textColor="#333333" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_revenue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#634335"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/stats_flow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Revenue"
                android:textColor="#D3C5BC"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/revenue_text_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 957.00"
                android:textColor="#FFFFFF"
                android:textSize="38sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2 completed orders"
                android:textColor="#D3C5BC" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <TextView
        android:id="@+id/tv_quick_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Quick Actions"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_revenue" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_incoming"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#F4EFE9"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_quick_actions">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">
            <ImageView
                android:id="@+id/img_box"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_circle"
                android:padding="12dp"
                android:src="@drawable/ic_orders"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:id="@+id/tv_incoming_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Incoming Orders"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/img_box"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/tv_incoming_sub"
                app:layout_constraintVertical_chainStyle="packed"/>
            <TextView
                android:id="@+id/tv_incoming_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 Pending Order"
                android:textColor="#666666"
                app:layout_constraintStart_toStartOf="@id/tv_incoming_title"
                app:layout_constraintTop_toBottomOf="@id/tv_incoming_title"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
          android:id="@+id/btn_menu_management"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginHorizontal="20dp"
          android:layout_marginTop="12dp"
          app:cardBackgroundColor="#F4EFE9"
          app:cardCornerRadius="32dp"
          app:cardElevation="0dp"
          app:layout_constraintTop_toBottomOf="@id/btn_incoming">

          <androidx.constraintlayout.widget.ConstraintLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:padding="12dp">

              <ImageView
                  android:id="@+id/img_menu"
                  android:layout_width="48dp"
                  android:layout_height="48dp"
                  android:background="@drawable/bg_icon_circle"
                  android:backgroundTint="#8BA888"
                  android:padding="12dp"
                  android:src="@drawable/ic_menu_management"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toTopOf="parent" />

              <TextView
                  android:id="@+id/tv_menu_title"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="16dp"
                  android:text="Menu Managment"
                  android:textColor="#000000"
                  android:textSize="16sp"
                  android:textStyle="bold"
                  app:layout_constraintStart_toEndOf="@id/img_menu"
                  app:layout_constraintTop_toTopOf="parent"
                  app:layout_constraintBottom_toTopOf="@id/tv_menu_sub"
                  app:layout_constraintVertical_chainStyle="packed"/>

              <TextView
                  android:id="@+id/tv_menu_sub"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="Update items and prices"
                  android:textColor="#666666"
                  app:layout_constraintStart_toStartOf="@id/tv_menu_title"
                  app:layout_constraintTop_toBottomOf="@id/tv_menu_title"
                  app:layout_constraintBottom_toBottomOf="parent"/>
          </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/label_recent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Recent Orders"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_menu_management" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_orders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:nestedScrollingEnabled="false"
        app:layout_constraintTop_toBottomOf="@id/label_recent"
        tools:listitem="@layout/item_order_row" />

 </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>